// Prisma Schema for OfferFlow - 求职简历投递管理系统
// 数据库: PostgreSQL（Vercel 生产环境）/ SQLite（本地开发，见 .env.development）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 岗位投递记录表
// ==========================================
model Application {
  id          String   @id @default(cuid())
  company     String   // 公司名称
  position    String   // 职位名称
  channel     String   @default("其他") // 投递渠道：官网/BOSS/猎聘/内推/其他
  department  String?  // 具体部门（如：商业化、基础架构）
  appliedDate DateTime @default(now())  // 投递日期
  status      String   @default("已投递") // 当前状态

  // JD 相关信息（OCR识别后填入）
  jdText      String?  // JD原文（OCR全文）
  jdRequire   String?  // 岗位要求（提取字段）
  jdDesc      String?  // 岗位描述（提取字段）

  notes       String?  // 备注信息

  // 关联简历版本（可选）
  resumeId    String?
  resume      Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  // 关联面试记录（一对多）
  interviews  Interview[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("applications")
}

// ==========================================
// 简历版本管理表
// ==========================================
model Resume {
  id           String   @id @default(cuid())
  name         String   // 简历名称（如"产品经理版"）
  filename     String   // 原始文件名
  filepath     String   // 服务器存储路径
  filesize     Int      @default(0) // 文件大小（字节）
  mimetype     String   @default("application/pdf") // MIME类型

  // 标签：JSON字符串，如 '["产品","AI","数据"]'
  tags         String   @default("[]")

  // 关联投递记录（一对多）
  applications Application[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("resumes")
}

// ==========================================
// 面试记录表
// ==========================================
model Interview {
  id            String   @id @default(cuid())

  // 关联岗位
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  round         String   // 面试轮次：一面/二面/三面/HR面/终面
  scheduledAt   DateTime // 面试时间
  interviewer   String?  // 面试官（姓名/部门）
  location      String?  // 面试地点（线上/线下/城市）

  // 面试详情
  questions     String?  // 面试题目（换行分隔）
  reflection    String?  // 面试复盘（支持Markdown）
  result        String?  // 结果：通过/未通过/待定

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("interviews")
}
